        "/transactions": {
            "post": {
                "tags": [
                    "Transaction"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "month": {
                                        "type": "string",
                                        "pattern": "^\\d{4}-(0[1-9]|1[0-2])$"
                                    },
                                    "name": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 99
                                    },
                                    "value": {
                                        "type": "number",
                                        "minimum": 0.01,
                                        "maximum": 999999999.99
                                    },
                                    "type": {
                                        "type": "string",
                                        "enum": [
                                            "expense",
                                            "income"
                                        ]
                                    },
                                    "category": {
                                        "type": "string",
                                        "enum": [
                                            "need",
                                            "want",
                                            "investment"
                                        ]
                                    }
                                },
                                "required": [
                                    "month",
                                    "name",
                                    "value",
                                    "type"
                                ]
                            }
                        }
                    }
                },
