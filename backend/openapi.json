                "type": "object",
                "properties": {
                    "code": {
                        "type": "string",
                        "const": "INTERNAL_SERVER_ERROR"
                    }
                },
                "required": [
                    "code"
                ],
                "additionalProperties": false
            },
            "InvalidCredentials": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "string",
                        "const": "INVALID_CREDENTIALS"
                    }
