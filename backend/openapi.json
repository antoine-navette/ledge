                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "userId": {
                        "type": "string"
                    },
                    "month": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "value": {
                        "type": "number"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "expense",
                            "income"
                        ]
                    },
                    "category": {
                        "type": "string",
                        "enum": [
                            "need",
                            "want",
                            "investment"
                        ]
