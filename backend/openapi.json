        "title": "Ledge API",
        "version": "1.0.0"
    },
    "components": {
        "schemas": {
            "User": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    },
                    "isEmailVerified": {
                        "type": "boolean"
                    },
                    "createdAt": {
                        "type": "string"
                    },
                    "updatedAt": {
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "email",
                    "isEmailVerified",
                    "createdAt",
                    "updatedAt"
                ],
                "additionalProperties": false
            },
            "BadRequest": {
                "type": "object",
